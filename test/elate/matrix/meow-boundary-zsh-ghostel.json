{
  "name": "meow-boundary-zsh-ghostel",
  "comment": "Input-region boundary matrix (zsh on ghostel, meow qwerty layout): autosuggestion / right-prompt / soft-wrap edges that the generic command matrix never exercises live. `x a` (select line + append) must clamp to the typed end instead of accepting the ghost; `x s` must not eat the right prompt. Run with --keep-going.",
  "session": {
    "ui": "tty",
    "size": "120x40",
    "config": "minimal",
    "env": {
      "ELATE_MEOW_DIR": "/Users/daniel/.cache/meow",
      "ELATE_GHOSTEL_DIR": "/Users/daniel/.emacs.d/lib/ghostel"
    },
    "eval": [
      "(load \"/Users/daniel/src/dakra/meow-ghostel/test/elate/lib/meow-ghostel-setup.el\")",
      "(setq ghostel-shell \"/bin/zsh\")"
    ]
  },
  "steps": [
    {
      "eval": "(ghostel)"
    },
    {
      "wait": "idle",
      "min_idle": 1.0,
      "timeout": 15.0
    },
    {
      "group": "prompt",
      "comment": "short prompt + shell helpers"
    },
    {
      "type": "PROMPT='> '; RPROMPT=''"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "idle",
      "min_idle": 0.5,
      "timeout": 5.0
    },
    {
      "group": "plugin",
      "comment": "load zsh-autosuggestions"
    },
    {
      "type": "source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "idle",
      "min_idle": 0.6,
      "timeout": 6.0
    },
    {
      "group": "sanity",
      "comment": "baseline typing + exec works"
    },
    {
      "type": "echo sane01"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^sane01$",
      "timeout": 8.0
    },
    {
      "group": "A1-line-append",
      "comment": "x a: line selection + append must clamp to typed end, not the ghost"
    },
    {
      "type": "echo hello world"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^hello world$",
      "timeout": 8.0
    },
    {
      "type": "echo hello"
    },
    {
      "wait": "idle",
      "min_idle": 1.3,
      "timeout": 8.0
    },
    {
      "eval": "(let ((l (buffer-substring-no-properties (line-beginning-position) (line-end-position)))) (unless (string-match-p \"echo hello world\" l) (error \"NO-LIVE-GHOST: %s\" l)))"
    },
    {
      "keys": "<escape> x a"
    },
    {
      "type": "X"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^helloX$",
      "timeout": 8.0
    },
    {
      "group": "A2-append",
      "comment": "A: open-below must land at typed end, not accept the ghost"
    },
    {
      "type": "echo hello world"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^hello world$",
      "timeout": 8.0
    },
    {
      "type": "echo hello"
    },
    {
      "wait": "idle",
      "min_idle": 1.3,
      "timeout": 8.0
    },
    {
      "eval": "(let ((l (buffer-substring-no-properties (line-beginning-position) (line-end-position)))) (unless (string-match-p \"echo hello world\" l) (error \"NO-LIVE-GHOST: %s\" l)))"
    },
    {
      "keys": "<escape> A"
    },
    {
      "type": "X"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^helloX$",
      "timeout": 8.0
    },
    {
      "group": "B-rp-on",
      "comment": "enable a right prompt '[RP]'"
    },
    {
      "type": "RPROMPT='[RP]'"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "idle",
      "min_idle": 0.5,
      "timeout": 5.0
    },
    {
      "group": "B1-append",
      "comment": "A X with a right prompt: must append after 'hi', not [RP]"
    },
    {
      "type": "echo hi"
    },
    {
      "keys": "<escape> A"
    },
    {
      "type": "X"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^hiX$",
      "timeout": 8.0
    },
    {
      "group": "B2-kill-line",
      "comment": "x s then retype: the line kill must delete only typed input, not [RP]"
    },
    {
      "type": "echo hi"
    },
    {
      "keys": "<escape> x s"
    },
    {
      "keys": "i"
    },
    {
      "type": "echo ok"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^ok$",
      "timeout": 8.0
    },
    {
      "group": "B-rp-off",
      "comment": "disable the right prompt"
    },
    {
      "type": "RPROMPT=''"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "idle",
      "min_idle": 0.5,
      "timeout": 5.0
    },
    {
      "group": "M1-build",
      "comment": "open quote + ENTER builds a 2-line input that executes"
    },
    {
      "type": "echo \"mlA"
    },
    {
      "keys": "RET"
    },
    {
      "type": "mlB\""
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^mlB$",
      "timeout": 8.0
    },
    {
      "group": "M2-append",
      "comment": "A X on a multi-line input lands at the true input end"
    },
    {
      "type": "echo \"keepA"
    },
    {
      "keys": "RET"
    },
    {
      "type": "keepB\""
    },
    {
      "keys": "<escape> A"
    },
    {
      "type": "X"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^keepBX$",
      "timeout": 8.0
    }
  ]
}
